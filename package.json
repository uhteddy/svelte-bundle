{
  "name": "svelte-bundle",
  "version": "0.2.0",
  "description": "A powerful CLI for scaffolding and bundling Svelte components",
  "type": "module",
  "bin": {
    "svelte-bundle": "./dist/cli.js",
    "sb": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "bun build src/cli.ts --outfile dist/cli.js --target node --format esm",
    "dev": "bun run src/cli.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "citty": "^0.1.6",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
