{
  "name": "svelte-bundle",
  "version": "0.4.0-beta.0",
  "description": "A powerful CLI for scaffolding and bundling Svelte components",
  "type": "module",
  "bin": {
    "svelte-bundle": "./dist/cli.js",
    "sb": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "repository": {
    "url": "https://github.com/uhteddy/svelte-bundle"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outfile dist/cli.js --target node --format esm",
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "type-check": "tsc --noEmit",
    "release": "release-it",
    "prepare": "husky"
  },
  "devDependencies": {
    "@clack/prompts": "^0.9.1",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/bun": "latest",
    "citty": "^0.1.6",
    "husky": "^9.1.7",
    "picocolors": "^1.1.1",
    "release-it": "^19.2.4",
    "typescript": "^5"
  }
}
